#!/usr/bin/env python3
import json
import os
import subprocess
import sys
import time
from datetime import datetime, timedelta
from pathlib import Path

CONFIG_DIR = Path.home() / '.config' / 'descanso-visual'
CONFIG_FILE = CONFIG_DIR / 'config.json'

DEFAULT_CONFIG = {
    "visual_interval_min": 20,
    "visual_duration_sec": 30,
    "active_interval_min": 60,
    "active_duration_sec": 180,
    "lunch_time": "12:00",
    "sleep_time": "22:30",
    "music_url": "https://streams.fluxfm.de/lofi/mp3-128/",
    "animal": "perro",
}

def load_config():
    if CONFIG_FILE.exists():
        with open(CONFIG_FILE) as f:
            cfg = json.load(f)
        return {**DEFAULT_CONFIG, **cfg}
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    with open(CONFIG_FILE, 'w') as f:
        json.dump(DEFAULT_CONFIG, f, indent=2)
    return dict(DEFAULT_CONFIG)

def play_music(url, duration):
    if not url:
        return
    for cmd in [
        ['ffplay', '-nodisp', '-autoexit', '-t', str(duration), url],
        ['mpv', '--no-video', '--length=' + str(duration), url],
    ]:
        try:
            subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return
        except FileNotFoundError:
            continue

def launch_break(mode, duration, animal):
    script = str(Path.home() / '.local' / 'bin' / 'pantalla-descanso')
    try:
        subprocess.run([sys.executable, script, str(duration), mode, animal])
    except Exception as e:
        print(f"Error: {mode} -> {e}")

def parse_time(t_str, day):
    h, m = t_str.split(':')
    return datetime(day.year, day.month, day.day, int(h), int(m))

STATS_FILE = CONFIG_DIR / 'stats.json'

def load_stats():
    try:
        if STATS_FILE.exists():
            with open(STATS_FILE) as f:
                return json.load(f)
    except Exception:
        pass
    return {}

def stats_summary(stats):
    from datetime import date
    today = date.today().isoformat()
    parts = []
    for modo, label in [('visual', 'visuales'), ('activo', 'activas'),
                         ('almuerzo', 'almuerzos'), ('dormir', 'dormir')]:
        if modo in stats:
            s = stats[modo]
            t = s['today'] if s.get('date') == today else 0
            tot = s['total']
            if t > 0 or tot > 0:
                parts.append(f"{t} {label} (total {tot})")
    return parts

def main():
    config = load_config()
    vi = config['visual_interval_min'] * 60
    ai = config['active_interval_min'] * 60

    next_visual = time.time()
    next_active = time.time() + ai
    last_lunch_date = None
    last_sleep_date = None

    animal = config['animal']
    music = config['music_url']
    stats = load_stats()

    print("── Descanso Visual ──")
    print(f"  Visual:   cada {config['visual_interval_min']} min  ({config['visual_duration_sec']}s)")
    print(f"  Activo:   cada {config['active_interval_min']} min  ({config['active_duration_sec']}s)")
    print(f"  Almuerzo: {config['lunch_time']}")
    print(f"  Dormir:   {config['sleep_time']}")
    print(f"  Animal:   {animal}")
    print(f"  Música:   {'sí' if music else 'no'}")
    parts = stats_summary(stats)
    if parts:
        print("── Estadísticas ────")
        for p in parts:
            print(f"  {p}")
    print("────────────────────")

    while True:
        now = datetime.now()
        hoy = now.date()

        if last_lunch_date != hoy:
            lunch = parse_time(config['lunch_time'], hoy)
            if lunch <= now <= lunch + timedelta(minutes=30):
                print(f"[{now.strftime('%H:%M')}] ⏰ Almuerzo")
                launch_break('almuerzo', 0, animal)
                stats = load_stats()
                for p in stats_summary(stats):
                    print(f"  {p}")
                last_lunch_date = hoy

        if last_sleep_date != hoy:
            sleep_t = parse_time(config['sleep_time'], hoy)
            if sleep_t <= now <= sleep_t + timedelta(minutes=30):
                print(f"[{now.strftime('%H:%M')}] 🌙 Dormir")
                launch_break('dormir', 0, animal)
                stats = load_stats()
                for p in stats_summary(stats):
                    print(f"  {p}")
                last_sleep_date = hoy

        if time.time() >= next_active:
            print(f"[{now.strftime('%H:%M')}] 🏃 Pausa activa")
            play_music(music, config['active_duration_sec'])
            launch_break('activo', config['active_duration_sec'], animal)
            stats = load_stats()
            for p in stats_summary(stats):
                print(f"  {p}")
            next_active = time.time() + ai
            next_visual = time.time() + ai

        if time.time() >= next_visual:
            print(f"[{now.strftime('%H:%M')}] 👀 Descanso visual")
            play_music(music, config['visual_duration_sec'])
            launch_break('visual', config['visual_duration_sec'], animal)
            stats = load_stats()
            for p in stats_summary(stats):
                print(f"  {p}")
            next_visual = time.time() + vi

        time.sleep(5)

if __name__ == '__main__':
    try:
        main()
    except KeyboardInterrupt:
        print("\nDetenido")
