            self.stats_updated = True
        Gtk.main_quit()

    def on_key(self, _widget, event):
        keyval = event.keyval
        if keyval == Gdk.KEY_space:
            self.do_skip()
            return True
        if keyval in (Gdk.KEY_z, Gdk.KEY_Z):
            self.do_snooze()
            return True
        if keyval == Gdk.KEY_Escape:
            if not TIENE_TEMPORIZADOR or self.tiempo_restante <= 0:
                self.do_skip()
            return True
        if keyval in (Gdk.KEY_Return, Gdk.KEY_KP_Enter):
            if self.btn_close.get_visible():
                self.on_close(None)
            return True
        return True


if __name__ == "__main__":
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    app = PantallaDescanso()
    app.show_all()
    Gtk.main()
