class PantallaDescanso(Gtk.Window):
    def __init__(self):
        super().__init__(type=Gtk.WindowType.TOPLEVEL)
        self.set_title("Descanso Visual")
        self.set_position(Gtk.WindowPosition.CENTER)
        self.set_resizable(False)
        self.set_decorated(False)
        self.set_keep_above(True)
        self.fullscreen()

        self.tiempo_restante = SEGUNDOS
        self.inicio = time.monotonic()

        screen = self.get_screen()
        visual = screen.get_rgba_visual()
        if visual:
            self.set_visual(visual)

        css = b"""
        window { background: #0a0a1a; }
        #clock { font-size: 96px; font-weight: bold; color: #e0e0ff; }
        #date  { font-size: 20px; color: #9090b0; margin-top: -10px; }
        #timer-text { font-size: 28px; color: #ffcc66; margin-top: 30px; }
        #fact { font-size: 18px; color: #b0b0d0; font-style: italic; margin-top: 40px; }
        #progress trough { min-height: 8px; border-radius: 4px; background: #1a1a3a; }
        #progress progress { min-height: 8px; border-radius: 4px; background: #6688ff; }
        #unlock-btn { font-size: 18px; padding: 12px 40px; background: #3344aa; color: white;
                      border: 2px solid #5566cc; border-radius: 8px; }
        #unlock-btn:hover { background: #4455cc; }
        """
        provider = Gtk.CssProvider()
        provider.load_from_data(css)
        Gtk.StyleContext.add_provider_for_screen(screen, provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        vbox.set_valign(Gtk.Align.CENTER)
        vbox.set_halign(Gtk.Align.CENTER)
        self.add(vbox)

        self.label_clock = Gtk.Label(name="clock")
        vbox.pack_start(self.label_clock, False, False, 0)

        self.label_date = Gtk.Label(name="date")
        vbox.pack_start(self.label_date, False, False, 10)

        self.label_timer = Gtk.Label(name="timer-text")
        vbox.pack_start(self.label_timer, False, False, 0)

        self.progress = Gtk.ProgressBar(name="progress")
        self.progress.set_size_request(400, -1)
        self.progress.set_margin_top(20)
        self.progress.set_margin_bottom(10)
        vbox.pack_start(self.progress, False, False, 0)

        self.label_fact = Gtk.Label(name="fact", label=random.choice(CURIOSIDADES))
        self.label_fact.set_line_wrap(True)
        self.label_fact.set_max_width_chars(50)
        self.label_fact.set_margin_top(20)
        vbox.pack_start(self.label_fact, False, False, 0)

        self.btn_unlock = Gtk.Button(label="Desbloquear", name="unlock-btn")
        self.btn_unlock.set_margin_top(40)
        self.btn_unlock.connect("clicked", self.on_unlock)
        self.btn_unlock.set_visible(False)
        vbox.pack_start(self.btn_unlock, False, False, 0)

        self.actualizar_reloj()

        GLib.timeout_add(100, self.actualizar_timer)
        GLib.timeout_add(1000, self.actualizar_reloj)

        self.connect("key-press-event", self.on_key)
        self.connect("destroy", Gtk.main_quit)
        self.connect("delete-event", lambda w, e: True)

    def actualizar_reloj(self):
        ahora = time.localtime()
        self.label_clock.set_text(time.strftime("%H:%M", ahora))
        self.label_date.set_text(time.strftime("%A, %d de %B de %Y", ahora).capitalize())
        return True

    def actualizar_timer(self):
        transcurrido = time.monotonic() - self.inicio
        restante = max(0, SEGUNDOS - transcurrido)
        self.tiempo_restante = int(restante)

        fraccion = transcurrido / SEGUNDOS
        self.progress.set_fraction(min(fraccion, 1.0))
        self.label_timer.set_text(f"Descansa {int(restante)} segundos más…")

        if restante <= 0:
            self.progress.set_fraction(1.0)
            self.label_timer.set_text("¡Ya puedes continuar!")
            self.btn_unlock.set_visible(True)
            self.btn_unlock.grab_focus()
            return False

        return True

    def on_unlock(self, _btn):
        Gtk.main_quit()

    def on_key(self, _widget, event):
        if event.keyval == Gdk.KEY_Escape and self.tiempo_restante <= 0:
            Gtk.main_quit()
        if event.keyval == Gdk.KEY_Return and self.tiempo_restante <= 0:
            if self.btn_unlock.get_visible():
                Gtk.main_quit()
        return True


if __name__ == "__main__":
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    app = PantallaDescanso()
    app.show_all()
    Gtk.main()
