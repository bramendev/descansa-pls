    def animar_animal(self):
        self.frame_idx = (self.frame_idx + 1) % len(FRAMES)
        self.label_animal.set_text('\n'.join(FRAMES[self.frame_idx]))
        return True

    def actualizar_timer(self):
        transcurrido = time.monotonic() - self.inicio
        restante = max(0, SEGUNDOS - transcurrido)
        self.tiempo_restante = int(restante)
        self.progress.set_fraction(min(transcurrido / SEGUNDOS, 1.0))
        self.label_timer.set_text(f"Descansa {int(restante)} segundos más…")

        if restante <= 0:
            self.progress.set_fraction(1.0)
            self.label_timer.set_text("¡Ya puedes continuar!")
            self.btn_close.set_visible(True)
            self.btn_close.grab_focus()
            return False
        return True

    def on_close(self, _btn):
        if not self.stats_updated:
            self.stats = increment_stat(MODO)
            self.stats_updated = True
        Gtk.main_quit()

    def do_snooze(self):
