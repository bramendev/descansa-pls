def load_stats():
    try:
        if STATS_FILE.exists():
            with open(STATS_FILE) as f:
                return json.load(f)
    except Exception:
        pass
    return {'visual': {'total': 0, 'today': 0, 'date': ''},
            'activo': {'total': 0, 'today': 0, 'date': ''},
            'almuerzo': {'total': 0, 'today': 0, 'date': ''},
            'dormir': {'total': 0, 'today': 0, 'date': ''}}

def save_stats(stats):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    with open(STATS_FILE, 'w') as f:
        json.dump(stats, f, indent=2)

def increment_stat(modo):
    stats = load_stats()
    today = date.today().isoformat()
    if modo not in stats:
        stats[modo] = {'total': 0, 'today': 0, 'date': today}
    if stats[modo].get('date') != today:
        stats[modo]['today'] = 0
    stats[modo]['total'] += 1
    stats[modo]['today'] += 1
    stats[modo]['date'] = today
    save_stats(stats)
    return stats

def get_stats_line(stats):
    today = date.today().isoformat()
    parts = []
    labels = {
        'visual': ('visuales', '👁'),
        'activo': ('activas', '🏃'),
        'almuerzo': ('almuerzos', '🍽'),
        'dormir': ('dormir', '🌙')
    }
    for modo, (label, icon) in labels.items():
        if modo in stats:
            s = stats[modo]
            if s.get('date') == today:
                t = s['today']
            else:
                t = 0
            if t > 0:
                parts.append(f"{icon} {t} {label}")
    if not parts:
        return "Hoy aún no hay pausas registradas"
    return "  ·  ".join(parts)

