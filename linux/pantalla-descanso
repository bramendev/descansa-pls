def _center(frames):
    w = max(len(l) for f in frames for l in f)
    return [[l.center(w) for l in f] for f in frames]

def load_config():
    try:
        if CONFIG_FILE.exists():
            with open(CONFIG_FILE) as f:
                return json.load(f)
    except Exception:
        pass
    return {}

def load_stats():
    try:
        if STATS_FILE.exists():
            with open(STATS_FILE) as f:
                return json.load(f)
    except Exception:
        pass
    return {}

def save_stats(stats):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    with open(STATS_FILE, 'w') as f:
        json.dump(stats, f, indent=2)

def increment_stat(modo):
    stats = load_stats()
    today = date.today().isoformat()
    for key in ('visual', 'activo', 'almuerzo', 'dormir', 'agua'):
        if key not in stats:
            stats[key] = {'total': 0, 'today': 0, 'date': today}
    if stats[modo].get('date') != today:
        stats[modo]['today'] = 0
    stats[modo]['total'] += 1
    stats[modo]['today'] += 1
    stats[modo]['date'] = today
    if 'history' not in stats:
        stats['history'] = {}
    if today not in stats['history']:
        stats['history'][today] = {}
    stats['history'][today][modo] = stats['history'][today].get(modo, 0) + 1
    cutoff = (date.today() - timedelta(days=30)).isoformat()
    stats['history'] = {k: v for k, v in stats['history'].items() if k >= cutoff}
    save_stats(stats)
    return stats

def get_stats_line(stats):
    today = date.today().isoformat()
    parts = []
    labels = {
        'visual': ('visuales', '👁'),
        'activo': ('activas', '🏃'),
        'almuerzo': ('almuerzos', '🍽'),
        'dormir': ('dormir', '🌙'),
        'agua': ('aguas', '💧')
    }
    for modo, (label, icon) in labels.items():
        if modo in stats:
            s = stats[modo]
            t = s['today'] if s.get('date') == today else 0
            if t > 0:
                parts.append(f"{icon} {t} {label}")
    if not parts:
        return "Hoy aún no hay pausas registradas"
    return "  ·  ".join(parts)

def get_weekly_stats(stats):
    today = date.today()
    week_start = today - timedelta(days=today.weekday())
    totals = {}
    for i in range(7):
        day = (week_start + timedelta(days=i)).isoformat()
        if day in stats.get('history', {}):
            for modo, count in stats['history'][day].items():
                totals[modo] = totals.get(modo, 0) + count
    return totals

def get_weekly_line(stats):
    weekly = get_weekly_stats(stats)
    if not weekly:
        return ""
    parts = []
    labels = {
        'visual': ('visuales', '👁'),
        'activo': ('activas', '🏃'),
        'almuerzo': ('almuerzos', '🍽'),
        'dormir': ('dormir', '🌙'),
        'agua': ('aguas', '💧')
    }
    for modo, count in sorted(weekly.items(), key=lambda x: -x[1]):
        if modo in labels and count > 0:
            label, icon = labels[modo]
            parts.append(f"{icon} {count} {label}")
    if not parts:
        return ""
    return "Semana: " + "  ·  ".join(parts)

