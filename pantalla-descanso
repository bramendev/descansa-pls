class PantallaDescanso:
    def __init__(self):
        self.root = tk.Tk()
        self.root.title(T['title_txt'])
        self.root.overrideredirect(True)
        self.root.attributes('-fullscreen', True)
        self.root.attributes('-topmost', True)
        self.root.configure(bg=T['bg'])
        self.root.focus_force()

        self.tiempo_restante = SEGUNDOS if TIENE_TIMER else 0
        self.inicio = time.monotonic()
        self.frame_idx = 0
        self.stats = load_stats()
        self.stats_updated = False

        self.style = ttk.Style()
        self.style.theme_use('clam')
        self.style.configure("custom.Horizontal.TProgressbar",
            troughcolor=T['ptrack'], background=T['pfill'],
            bordercolor=T['bg'], lightcolor=T['pfill'], darkcolor=T['pfill'])

        self._build_ui()
        self._bind_keys()

        self.root.after(100, self._tick)
        if TIENE_TIMER:
            self.root.after(400, self._animar)
            self.root.after(100, self._timer_tick)

    def _build_ui(self):
        self.root.grid_columnconfigure(0, weight=1)
        self.root.grid_rowconfigure(0, weight=1)

        f = tk.Frame(self.root, bg=T['bg'])
        f.grid(row=0, column=0)

        self.label_clock = tk.Label(f, bg=T['bg'], fg=T['clock'],
            font=(SANS, 80, 'bold'))
        self.label_clock.pack(pady=(40, 0))

        self.label_date = tk.Label(f, bg=T['bg'], fg=T['date'],
            font=(SANS, 16))
        self.label_date.pack()

        y = 0
        if WEATHER:
            tk.Label(f, bg=T['bg'], fg=T['date'], font=(SANS, 14),
                text=WEATHER).pack()
            y = 1

        if TIENE_TIMER:
