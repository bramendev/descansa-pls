                font=(MONO, 16), justify='center')
            self.label_animal.pack(pady=(20, 0))

            self.label_timer = tk.Label(f, bg=T['bg'], fg=T['timer'],
                font=(SANS, 22))
            self.label_timer.pack(pady=(16, 0))

            self.progress = ttk.Progressbar(f, style="custom.Horizontal.TProgressbar",
                length=380, mode='determinate')
            self.progress.pack(pady=(10, 8))

            pool = _CURIOSIDADES + _MOTIVACIONALES if MODO == 'visual' else _EJERCICIOS + _MOTIVACIONALES
            self.label_info = tk.Label(f, bg=T['bg'], fg=T['info'],
                font=(SANS, 16, 'italic'), wraplength=600)
            self.label_info.pack(pady=(16, 0))
            self.label_info.config(text=random.choice(pool))
        else:
            icon_lines = BOWL if MODO == 'almuerzo' else MOON if MODO == 'dormir' else WATER
            icon_text = '\n'.join(l.center(max(len(r) for r in icon_lines)) for l in icon_lines)
            tk.Label(f, bg=T['bg'], fg=T['animal'],
                font=(MONO, 16), text=icon_text, justify='center').pack(pady=(20, 0))

            tk.Label(f, bg=T['bg'], fg=T['title'],
                font=(SANS, 36, 'bold'), text=T['title_txt']).pack(pady=(20, 0))

            pool = _COMIDAS if MODO == 'almuerzo' else _DORMIR_TIPS if MODO == 'dormir' else _AGUA_MSGS
            tk.Label(f, bg=T['bg'], fg=T['text'],
                font=(SANS, 20), wraplength=600, text=random.choice(pool)).pack(pady=(12, 0))

            foot = "Bebe despacio, disfruta cada sorbo." if MODO == 'agua' else "Tómate tu tiempo, la pantalla seguirá aquí."
            tk.Label(f, bg=T['bg'], fg=T['info'],
                font=(SANS, 14, 'italic'), text=foot).pack(pady=(12, 0))

        stats_line = get_stats_line(self.stats)
        self.label_stats = tk.Label(f, bg=T['bg'], fg=T['date'],
            font=(SANS, 13))
        self.label_stats.pack(pady=(12, 0))
        self.label_stats.config(text=stats_line)

        weekly_line = get_weekly_line(self.stats)
        if weekly_line:
            tk.Label(f, bg=T['bg'], fg=T['date'],
                font=(SANS, 12), text=weekly_line).pack()

        if not TIENE_TIMER:
            auto_ms = 10000 if MODO == 'agua' else 600000
            self.root.after(auto_ms, self.do_skip)

        btn_text = "Cerrar" if not TIENE_TIMER else "Desbloquear"
        self.btn = tk.Button(f, text=btn_text,
            font=(SANS, 16, 'bold'), bg=T['btn'], fg='white',
            activebackground=T['bord'], activeforeground='white',
            bd=2, relief='solid', highlightbackground=T['bord'],
            cursor='hand2', padx=40, pady=12)
        self.btn.config(command=self.do_skip)
        if TIENE_TIMER:
            self.btn.pack_forget()
        else:
            self.btn.pack(pady=(16, 0))

        hint = "Espacio: saltar  ·  Z: snooze 5 min" if TIENE_TIMER else "Espacio o Z: cerrar"
        tk.Label(f, bg=T['bg'], fg=T['date'],
            font=(SANS, 11), text=hint).pack(pady=(8, 0))

    def _bind_keys(self):
        self.root.bind('<Key-space>', lambda e: self.do_skip())
        self.root.bind('<Key-z>', lambda e: self.do_snooze())
        self.root.bind('<Key-Z>', lambda e: self.do_snooze())
        self.root.bind('<Escape>', lambda e: self.do_skip() if (not TIENE_TIMER or self.tiempo_restante <= 0) else None)
        self.root.bind('<Return>', lambda e: self.do_skip() if (self.btn.winfo_viewable()) else None)
        self.root.bind('<KP_Enter>', lambda e: self.do_skip() if (self.btn.winfo_viewable()) else None)

    def _tick(self):
        ahora = time.localtime()
        self.label_clock.config(text=time.strftime("%H:%M", ahora))
        self.label_date.config(text=time.strftime("%A, %d de %B de %Y", ahora).capitalize())
        self.root.after(1000, self._tick)

    def _animar(self):
        self.frame_idx = (self.frame_idx + 1) % len(FRAMES)
        self.label_animal.config(text='\n'.join(FRAMES[self.frame_idx]))
        self.root.after(400, self._animar)

    def _timer_tick(self):
        transcurrido = time.monotonic() - self.inicio
        restante = max(0, SEGUNDOS - transcurrido)
        self.tiempo_restante = int(restante)
        pct = min(transcurrido / SEGUNDOS, 1.0) * 100
        self.progress['value'] = pct
        self.label_timer.config(text=f"Descansa {int(restante)} segundos más…")

        if restante <= 0:
            self.progress['value'] = 100
            self.label_timer.config(text="¡Ya puedes continuar!")
            self.btn.pack(pady=(16, 0))
            return

        self.root.after(100, self._timer_tick)

    def _cleanup(self):
        if not self.stats_updated:
            self.stats = increment_stat(MODO)
            self.stats_updated = True

    def do_snooze(self):
        write_snooze()
        self._cleanup()
        self.root.destroy()

    def do_skip(self):
        self._cleanup()
        self.root.destroy()


